# ─── App ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
NEST_API_URL=http://localhost:3000/api/

# ─── Cloudinary ─────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=medikita
# API key is safe to expose; the SDK widget needs it client-side.
NEXT_PUBLIC_CLOUDINARY_API_KEY=cloud_api_key
# Secret stays server-only (used by /api/cloudinary/sign).
CLOUDINARY_API_SECRET=cloud_api_secret
